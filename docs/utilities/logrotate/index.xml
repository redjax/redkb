&lt;h3&gt;Apply policy to any .log file in /var/log&lt;span class="hx:absolute hx:-mt-20" id="apply-policy-to-any-log-file-in-varlog"&gt;&lt;/span&gt;
&lt;a href="#apply-policy-to-any-log-file-in-varlog" class="subheading-anchor" aria-label="Permalink for this section"&gt;&lt;/a&gt;&lt;/h3&gt;&lt;div class="hextra-code-block hx:relative hx:mt-6 hx:first:mt-0 hx:group/code"&gt;
&lt;div&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" class="chroma"&gt;&lt;code class="language-plaintext" data-lang="plaintext"&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;/var/log/myapp/*.log {
